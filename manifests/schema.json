{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Off-Grid 3D Print Library Model Entry",
  "type": "object",
  "required": ["id", "category_num", "name", "description", "material_rec",
               "source_license", "source_site"],
  "properties": {
    "id":             { "type": "string", "pattern": "^OG-[0-9]{3}$",
                        "description": "Unique library ID, e.g. OG-042" },
    "category_num":   { "type": "string", "pattern": "^[0-9]{2}$",
                        "description": "Two-digit category: 01-10 or 99" },
    "category_name":  { "type": "string" },
    "name":           { "type": "string", "maxLength": 80 },
    "description":    { "type": "string", "maxLength": 300 },
    "material_rec":   { "type": "string",
                        "enum": ["PLA","PETG","ABS","ASA","TPU","NYLON","PC","PETG or ASA","ASA or ABS"] },
    "infill_pct":     { "type": "integer", "minimum": 10, "maximum": 100 },
    "supports_needed":{ "type": "string", "enum": ["Yes","No","Optional"] },
    "source_license": { "type": "string",
                        "enum": ["CC0","CC BY","CC BY-SA","CC BY-NC","CC BY-NC-SA","MIT","GPL"] },
    "source_site":    { "type": "string",
                        "enum": ["Printables","Thingiverse","GitHub","Makerworld","Original"] },
    "page_url":       { "type": "string", "format": "uri" },
    "download_url":   { "type": "string", "format": "uri" },
    "local_path":     { "type": "string",
                        "description": "Relative path under models/ if downloaded" },
    "notes":          { "type": "string", "maxLength": 500 }
  }
}
